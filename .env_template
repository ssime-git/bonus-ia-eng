# Copier ce fichier en `.env` (jamais commité — couvert par .gitignore) et
# renseigner votre clé. (Optionnel) pour les parties LLM :

# Exemple Groq (gratuit — clé sur https://console.groq.com) :
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=votre-cle
LLM_MODEL=llama-3.3-70b-versatile

# Lue en priorité par les notebooks (J4) quand le champ clé est vide :
GROQ_API_KEY=votre-cle

# Variante OpenAI :
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
